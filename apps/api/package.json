{
  "name": "@cfp/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute cash-flow-pulse-db --file=./src/db/schema.sql",
    "db:reset": "wrangler d1 execute cash-flow-pulse-db --file=./src/db/schema.sql --remote",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cfp/shared": "workspace:*",
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "wrangler": "^3.99.0"
  }
}